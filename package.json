{
  "name": "nuviotv-scrapers",
  "version": "5.0.0",
  "description": "NuvioTV streaming scrapers with TypeScript, caching, subtitles, and analytics",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --forceExit",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage --forceExit",
    "health": "node --loader ts-node/esm src/health/check.ts",
    "report": "node --loader ts-node/esm src/analytics/report.ts"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "keywords": ["nuvio", "streaming", "scrapers", "typescript"],
  "license": "MIT"
}
